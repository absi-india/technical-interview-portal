# ─── LOCAL DEV ────────────────────────────────────────────────────────────────
# Copy to .env and fill in values.

# App
APP_DOMAIN=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-strong-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local dev: SQLite file
DATABASE_URL="file:./dev.db"
DATABASE_AUTH_TOKEN=   # leave empty for local file

# Production (Turso — free): https://app.turso.tech
# DATABASE_URL="libsql://<db-name>.turso.io"
# DATABASE_AUTH_TOKEN="<token from turso auth token>"

# ─── REDIS ────────────────────────────────────────────────────────────────────
# Local dev
REDIS_URL=redis://localhost:6379

# Production (Upstash — free): https://console.upstash.com
# REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"

# ─── CRON (Vercel cron security) ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me-to-a-random-secret

# ─── OBJECT STORAGE (optional — videos / resumes) ────────────────────────────
# Local dev: MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_RESUMES=resumes

# Production: Cloudflare R2 (free 10 GB/month) — S3-compatible
# MINIO_ENDPOINT=<account-id>.r2.cloudflarestorage.com
# MINIO_PORT=443
# MINIO_ACCESS_KEY=<r2-access-key-id>
# MINIO_SECRET_KEY=<r2-secret-access-key>
# MINIO_BUCKET_RECORDINGS=recordings
# MINIO_BUCKET_RESUMES=resumes

# ─── AI ───────────────────────────────────────────────────────────────────────
# Gemini API (FREE tier) — https://aistudio.google.com/app/apikey
# Free: 15 req/min, 1M tokens/day on gemini-1.5-flash
GEMINI_API_KEY=AIza...

# ─── SMTP EMAIL (optional) ────────────────────────────────────────────────────
# Free option: Resend (https://resend.com) — 3,000 emails/month
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=<resend-api-key>
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=yourpassword
SMTP_FROM="Interview Portal <noreply@yourdomain.com>"

# ─── PLATFORM ─────────────────────────────────────────────────────────────────
COMPANY_NAME="Your Company Name"

# ─── SEED (first-run admin account) ──────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production
